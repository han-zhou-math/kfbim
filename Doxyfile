PROJECT_NAME           = "KFBIM"
PROJECT_BRIEF          = "Kernel-free boundary integral method C++ library"
OUTPUT_DIRECTORY       = build/docs/doxygen
CREATE_SUBDIRS         = NO

INPUT                  = README.md \
                         AGENTS.md \
                         PROGRESS.md \
                         core \
                         problems \
                         notes
USE_MDFILE_AS_MAINPAGE = README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp \
                         *.cpp \
                         *.md
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES
SEARCHENGINE           = YES

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = NO
WARN_NO_PARAMDOC       = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

HAVE_DOT               = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
